import tkinter as tk
from tkinter import messagebox, ttk
import random
import json
import os

# Список предопределённых задач с типами
tasks = {
    "учёба": ["Прочитать статью", "Решить 5 задач по математике", "Выучить 20 слов на английском"],
    "спорт": ["Сделать зарядку", "Пробежать 3 км", "Позаниматься йогой 30 минут"],
    "работа": ["Проверить почту", "Составить отчёт", "Провести встречу с командой"]
}

# Файл для сохранения истории
HISTORY_FILE = "task_history.json"

class RandomTaskGenerator:
    def __init__(self, root):
        self.root = root
        self.root.title("Random Task Generator")
        self.root.geometry("500x400")

        # Загрузка истории
        self.history = self.load_history()

        self.setup_ui()

    def setup_ui(self):
        # Выпадающий список для фильтрации по типу
        ttk.Label(self.root, text="Тип задачи:").pack(pady=5)
        self.type_var = tk.StringVar(value="все")
        type_combo = ttk.Combobox(
            self.root,
            textvariable=self.type_var,
            values=["все", "учёба", "спорт", "работа"]
        )
        type_combo.pack(pady=5)

        # Кнопка генерации
        generate_btn = tk.Button(
            self.root,
            text="Сгенерировать задачу",
            command=self.generate_task
        )
        generate_btn.pack(pady=10)

        # Поле для отображения текущей задачи
        self.current_task_label = tk.Label(
            self.root,
            text="",
            wraplength=400,
            font=("Arial", 12, "bold")
        )
        self.current_task_label.pack(pady=10)

        # Список истории
        ttk.Label(self.root, text="История задач:").pack(pady=5)
        self.history_listbox = tk.Listbox(self.root, height=10, width=60)
        self.history_listbox.pack(pady=5, padx=10, fill=tk.BOTH, expand=True)

        # Обновление списка истории
        self.update_history_list()

    def generate_task(self):
        selected_type = self.type_var.get()

        if selected_type == "все":
            all_tasks = [task for task_list in tasks.values() for task in task_list]
            task = random.choice(all_tasks)
        else:
            if not tasks[selected_type]:
                messagebox.showwarning("Предупреждение", "Нет задач этого типа")
                return
            task = random.choice(tasks[selected_type])

        # Добавляем в историю
        self.history.append(task)
        self.save_history()
        self.update_history_list()
        self.current_task_label.config(text=task)

    def update_history_list(self):
        self.history_listbox.delete(0, tk.END)
        for task in reversed(self.history[-20:]):  # Показываем последние 20 задач
            self.history_listbox.insert(tk.END, task)

    def save_history(self):
        with open(HISTORY_FILE, 'w', encoding='utf-8') as f:
            json.dump(self.history, f, ensure_ascii=False, indent=2)

    def load_history(self):
        if os.path.exists(HISTORY_FILE):
            with open(HISTORY_FILE, 'r', encoding='utf-8') as f:
                return json.load(f)
        return []

if __name__ == "__main__":
    root = tk.Tk()
    app = RandomTaskGenerator(root)
    root.mainloop()
